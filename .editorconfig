# EditorConfig is awesome: https://EditorConfig.org
# This is the top-most EditorConfig file for the repo. Vendored third-party code under
# libraries/ (Adafruit_*, FastLED, LovyanGFX, AUnit, ArduinoJson, etc.) is deliberately
# excluded from the opinionated C++ style below via libraries/.editorconfig, which sets
# root = true to stop this file's rules from cascading into it. libraries/Woyak/.editorconfig
# then re-applies this project's style just for the first-party Woyak library.
root = true

# Defaults for all files
[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

# First-party C/C++ source: Arduino sketches (*.ino) and their headers at the repo root
# and under Tests/. (libraries/ is excluded by libraries/.editorconfig; see note above.)
[*.{ino,cpp,h,hpp}]
indent_style = space
indent_size = 3

# Brace style: Allman (open brace on its own line), enforced via Visual Studio's
# C++ formatting options rather than EditorConfig alone.
cpp_new_line_before_open_brace_namespace = true
cpp_new_line_before_open_brace_type = true
cpp_new_line_before_open_brace_function = true
cpp_new_line_before_open_brace_block = true
cpp_new_line_before_open_brace_lambda = true
cpp_indent_braces = false
cpp_indent_case_labels = true

# MSBuild project files
[*.{vcxproj,vcxproj.filters,props,targets}]
indent_style = space
indent_size = 2

[*.sln]
indent_style = tab

[*.{json,yml,yaml}]
indent_style = space
indent_size = 2
